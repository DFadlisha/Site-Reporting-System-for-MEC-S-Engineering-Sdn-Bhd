// storage.rules
// Deploy with: firebase deploy --only storage

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /reports/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /issues/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
}
}
